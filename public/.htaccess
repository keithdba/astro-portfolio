# Deny access to .env files
<FilesMatch "^\.env|private\.env$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Enable Rewrite Engine
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Enforce canonical domain: redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.macdaly\.com [NC]
  RewriteRule ^(.*)$ https://macdaly.com/$1 [L,R=301]

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove trailing slashes (optional, but good for SEO matching clean URLs)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # Custom 404 Error Page
  # ErrorDocument 404 /404.html

  # SSR Configuration
  # Passenger is typically enabled via the cPanel UI, but this ensures fallback
  PassengerEnabled on
  PassengerAppType node
  PassengerStartupFile app.js
</IfModule>
