---
---

<div id="messageModal" class="modal-overlay hidden">
  <div class="modal-container">
    <div class="modal-content glass-panel">
      <header class="modal-header">
        <div class="sender-profile">
          <div class="avatar" id="modalAvatar">M</div>
          <div class="sender-info">
            <h2 id="modalSender">Sender Name</h2>
            <p id="modalEmail">sender@example.com</p>
          </div>
        </div>
        <div class="modal-meta">
          <span id="modalDate">Jan 1, 2026</span>
          <button id="closeModal" class="btn-close-circle" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </header>

      <div class="modal-body">
        <div class="message-label">MESSAGE</div>
        <div id="modalBodyText" class="message-content">
          <!-- Message text goes here -->
        </div>
      </div>

      <footer class="modal-footer">
        <div class="status-actions">
          <button id="modalActionRead" class="btn-action">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            <span>Mark as Read</span>
          </button>
          <button id="modalActionArchive" class="btn-action">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>
            <span>Archive</span>
          </button>
        </div>
        <button id="modalActionDelete" class="btn-danger-alt">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
          <span>Delete</span>
        </button>
      </footer>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('messageModal');
  const closeBtn = document.getElementById('closeModal');
  const modalSender = document.getElementById('modalSender');
  const modalAvatar = document.getElementById('modalAvatar');
  const modalEmail = document.getElementById('modalEmail');
  const modalDate = document.getElementById('modalDate');
  const modalBodyText = document.getElementById('modalBodyText');
  
  const readBtn = document.getElementById('modalActionRead');
  const archiveBtn = document.getElementById('modalActionArchive');
  const deleteBtn = document.getElementById('modalActionDelete');

  let currentMsgId = null;

  window.addEventListener('view-message', (e: any) => {
    const msg = e.detail;
    currentMsgId = msg.id;
    
    modalSender.textContent = msg.sender_name;
    modalAvatar.textContent = msg.sender_name.charAt(0).toUpperCase();
    modalEmail.textContent = msg.sender_email;
    modalDate.textContent = new Date(msg.timestamp).toLocaleString(undefined, {
      month: 'long', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit'
    });
    modalBodyText.textContent = msg.message_body;
    
    // Update button labels
    readBtn.querySelector('span').textContent = msg.status === 'unread' ? 'Mark as Read' : 'Mark as Unread';
    archiveBtn.querySelector('span').textContent = msg.status === 'archived' ? 'Restore to Inbox' : 'Archive';

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    if (msg.status === 'unread') {
      updateMsgStatus(msg.id, 'read');
    }
  });

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    currentMsgId = null;
  }

  closeBtn.onclick = closeModal;
  modal.onclick = (e) => { if (e.target === modal) closeModal(); };

  async function updateMsgStatus(id, newStatus) {
    try {
      const resp = await fetch(`/api/messages/${id}`, {
        method: 'PATCH',
        headers: { 
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') as HTMLMetaElement)?.content || ''
        },
        body: JSON.stringify({ status: newStatus })
      });
      if (resp.ok) {
        window.dispatchEvent(new CustomEvent('refresh-inbox'));
        if (currentMsgId === id) {
          readBtn.querySelector('span').textContent = newStatus === 'unread' ? 'Mark as Read' : 'Mark as Unread';
          archiveBtn.querySelector('span').textContent = newStatus === 'archived' ? 'Restore to Inbox' : 'Archive';
          if (newStatus === 'archived') closeModal();
        }
      }
    } catch (err) {
      console.error('Update failed', err);
    }
  }

  readBtn.onclick = () => {
    const isUnread = readBtn.querySelector('span').textContent.includes('Read');
    updateMsgStatus(currentMsgId, isUnread ? 'read' : 'unread');
  };

  archiveBtn.onclick = () => {
    const isArchived = archiveBtn.querySelector('span').textContent.includes('Restore');
    updateMsgStatus(currentMsgId, isArchived ? 'read' : 'archived');
  };

  deleteBtn.onclick = async () => {
    if (!confirm('Are you sure you want to delete this message?')) return;
    try {
      const resp = await fetch(`/api/messages/${currentMsgId}`, {
        method: 'DELETE',
        headers: { 
          'X-Requested-With': 'XMLHttpRequest',
          'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') as HTMLMetaElement)?.content || ''
        }
      });
      if (resp.ok) {
        window.dispatchEvent(new CustomEvent('refresh-inbox'));
        closeModal();
      }
    } catch (err) {
      console.error('Delete failed', err);
    }
  };
</script>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    padding: 1.5rem;
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal-container {
    width: 100%;
    max-width: 800px;
    animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-content {
    background: var(--bg-color);
    padding: 3rem;
    overflow: hidden;
    position: relative;
  }

  :global(.dark) .modal-content {
    background: #1e293b;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2.5rem;
  }

  .sender-profile {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--tech-blue);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .sender-info h2 {
    font-size: 1.5rem;
    color: var(--text-main);
    margin: 0;
  }

  .sender-info p {
    color: var(--text-muted);
    font-weight: 600;
    margin: 0.2rem 0 0 0;
  }

  .modal-meta {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .modal-meta span {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .btn-close-circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: var(--glass-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: all 0.2s ease;
  }

  .btn-close-circle:hover {
    background: #ef4444;
    color: white;
    transform: rotate(90deg);
  }

  .modal-body {
    padding: 2rem 0;
    border-top: 1px solid var(--glass-border);
    margin-bottom: 2.5rem;
  }

  .message-label {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--tech-blue);
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .message-content {
    white-space: pre-wrap;
    line-height: 1.8;
    color: var(--text-main);
    font-size: 1.125rem;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 1rem;
  }

  .modal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--glass-border);
  }

  .status-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-action {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-action:hover {
    border-color: var(--tech-blue);
    background: rgba(30, 168, 236, 0.1);
    color: var(--tech-blue);
  }

  .btn-danger-alt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 12px;
    border: 1px solid transparent;
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-danger-alt:hover {
    background: #ef4444;
    color: white;
  }

  .hidden { display: none !important; }

  @media (max-width: 640px) {
    .modal-content { padding: 1.5rem; }
    .modal-header { flex-direction: column; gap: 1.5rem; }
    .modal-meta { text-align: left; align-items: flex-start; width: 100%; justify-content: space-between; flex-direction: row-reverse; }
    .modal-footer { flex-direction: column-reverse; gap: 1.5rem; align-items: stretch; }
    .status-actions { flex-direction: column; }
    .btn-action, .btn-danger-alt { justify-content: center; }
  }
</style>
