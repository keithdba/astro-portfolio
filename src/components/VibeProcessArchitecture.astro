---
interface Props {
  entry: {
    data: {
      title: string;
      subtitle: string;
      heroImage?: string;
      intro: {
        left: string[];
        right: string[];
      };
      processFlow: {
        heading: string;
        description: string;
        details?: string[];
      }[];
      highlight: {
        title: string;
        points: string[];
      };
      roadmap: {
        heading: string;
        description: string;
      }[];
    }
  };
}

const { entry } = Astro.props;
const { data } = entry;
---

<div class="vibe-process">
  {/* 1. Hero Section */}
  <section class="hero-section">
    <div class="hero-text">
      <h1 class="hero-title">{data.title}</h1>
      <p class="hero-subtitle">{data.subtitle}</p>
    </div>
    <div class="diagram-container">
      <img 
        src="/assets/pro/vibe-coding-architecture-diagram.png" 
        alt="Vibe Coding System Architecture Diagram" 
        class="architecture-diagram"
      />
    </div>
  </section>

  {/* 2. Two-Column Intro Block */}
  <section class="intro-block">
    <div class="intro-grid">
      <div class="intro-left">
        {data.intro.left.map(p => <p class="intro-text">{p}</p>)}
      </div>
      <div class="intro-right">
        <h4 class="principles-heading">Core Principles</h4>
        <ul class="principles-list">
          {data.intro.right.map(p => <li>{p}</li>)}
        </ul>
      </div>
    </div>
  </section>

  {/* New Callout: Why This Architecture Matters */}
  <section class="why-matters">
    <div class="callout-card">
      <h2 class="callout-title">Why This Architecture Matters</h2>
      <div class="callout-content">
        <p>This multi-layer workflow isn't just about speed; it's about <strong>cognitive shift</strong>. By separating Intent (Human) from Structure (Copilot) and Execution (Antigravity), we eliminate the brittle "prompt-as-code" trap. The system remains flexible, the human remains strategic, and the output remains resilient to technical drift.</p>
      </div>
    </div>
  </section>

  {/* 3. Vertical Process Flow */}
  <section class="process-flow">
    <h2 class="section-title">Execution Workflow</h2>
    <div class="flow-container">
      {data.processFlow.map((item, i) => (
        <div class="flow-item">
          <div class="flow-marker">
            <span class="marker-line"></span>
            <span class="marker-dot">{i + 1}</span>
          </div>
          <div class="flow-content">
            <h3 class="flow-heading">{item.heading}</h3>
            <p class="flow-description">{item.description}</p>
            {item.details && (
              <ul class="flow-details">
                {item.details.map(d => <li>{d}</li>)}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* 4. Highlight Block */}
  <section class="highlight-block">
    <div class="highlight-card">
      <h2 class="highlight-title">{data.highlight.title}</h2>
      <div class="highlight-grid">
        {data.highlight.points.map(p => (
          <div class="highlight-item">
            <span class="highlight-check">✓</span>
            <p>{p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Update roadmap section if needed, or keep as is with new styles */}

  {/* 6. Footer Callout */}
  <footer class="branded-footer-callout">
    <div class="footer-line"></div>
    <div class="footer-content">
      <div class="footer-logo-wrapper">
        <img src="/assets/branding/logo-pro.png" alt="MacDaly.com" class="footer-logo-img" />
      </div>
      <span class="footer-tagline">Innovate • Automate • Deliver</span>
    </div>
  </footer>
</div>

<style>
  .footer-logo-wrapper {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }
  .footer-logo-img {
    height: 50px;
    width: auto;
    object-fit: contain;
  }
  .vibe-process {
    padding-top: 2rem;
    color: var(--text-main);
  }

  /* Hero Section */
  .hero-section {
    text-align: center;
    margin-bottom: 6rem;
  }

  .hero-text {
    margin-bottom: 4rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 1;
    color: var(--accent-graphite);
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--tech-blue);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .diagram-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.5rem;
    background: #fff;
    border-radius: 32px;
    box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--performance-silver);
    transition: transform 0.5s ease;
  }
  .diagram-container:hover {
    transform: scale(1.02);
  }

  .architecture-diagram {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Intro Grid */
  .intro-block {
    margin-bottom: 8rem;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: start;
  }

  .intro-left {
    font-size: 1.25rem;
    line-height: 1.75;
    color: var(--text-main);
  }

  .intro-text {
    margin-bottom: 1.5rem;
  }

  .intro-right {
    background: #f8fafc;
    padding: 2.5rem;
    border-radius: 24px;
    border: 1px solid var(--performance-silver);
  }

  .principles-heading {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .principles-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .principles-list li {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--accent-graphite);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .principles-list li::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--tech-blue);
    border-radius: 2px;
    transform: rotate(45deg);
  }

  /* Why Matters Callout */
  .why-matters {
    margin-bottom: 8rem;
    width: 100%;
  }
  .callout-card {
    background: linear-gradient(135deg, var(--accent-graphite) 0%, #1a1a1a 100%);
    color: #fff;
    padding: 4rem;
    border-radius: 32px;
    position: relative;
    overflow: hidden;
  }
  .callout-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(30, 168, 236, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .callout-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--tech-blue);
    letter-spacing: -0.02em;
  }
  .callout-content p {
    font-size: 1.5rem;
    line-height: 1.6;
    max-width: 900px;
    color: var(--performance-silver);
    font-weight: 300;
  }
  .callout-content strong {
    color: #fff;
    font-weight: 700;
  }

  /* Vertical Process Flow */
  .process-flow {
    margin-bottom: 8rem;
  }
  .section-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-graphite);
    margin-bottom: 4rem;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .flow-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .flow-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
  }

  .flow-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .marker-line {
    flex: 1;
    width: 3px;
    background: var(--performance-silver);
    opacity: 0.3;
  }

  .flow-item:first-child .marker-line {
    background: linear-gradient(to top, var(--performance-silver), transparent);
  }

  .flow-item:last-child .marker-line {
    background: linear-gradient(to bottom, var(--performance-silver), transparent);
  }

  .marker-dot {
    width: 48px;
    height: 48px;
    background: var(--tech-blue);
    color: #fff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 800;
    z-index: 10;
    margin: 1rem 0;
    box-shadow: 0 10px 20px -5px rgba(30, 168, 236, 0.4);
    transform: rotate(5deg);
  }

  .flow-content {
    padding: 3rem 0;
  }

  .flow-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent-graphite);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .flow-description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .flow-details {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .flow-details li {
    font-size: 1rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 500;
  }

  .flow-details li::before {
    content: '→';
    color: var(--tech-blue);
    font-weight: 800;
  }

  /* Highlight Block */
  .highlight-block {
    margin-bottom: 8rem;
  }

  .highlight-card {
    background: #f8fafc;
    padding: 5rem;
    border-radius: 40px;
    text-align: center;
    border: 1px solid var(--performance-silver);
  }

  .highlight-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 4rem;
    letter-spacing: -0.03em;
    color: var(--accent-graphite);
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 3rem;
  }

  .highlight-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .highlight-check {
    width: 60px;
    height: 60px;
    background: var(--tech-blue);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 800;
    box-shadow: 0 15px 30px -10px rgba(30, 168, 236, 0.4);
  }

  .highlight-item p {
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-graphite);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Footer Callout */
  .branded-footer-callout {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid var(--performance-silver);
  }

  .footer-line {
    width: 80px;
    height: 2px;
    background: var(--tech-blue);
    margin: 0 auto 3rem;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent-graphite);
    letter-spacing: -0.02em;
  }

  .footer-tagline {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.3rem;
  }

  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
    .flow-item {
      grid-template-columns: 80px 1fr;
    }
    .callout-card {
      padding: 2.5rem;
    }
    .callout-title {
      font-size: 1.75rem;
    }
    .callout-content p {
      font-size: 1.125rem;
    }
    .flow-details {
      grid-template-columns: 1fr;
    }
  }
</style>
