---
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/admin/ThemeToggle.astro';
import { requireAdmin } from '../../lib/auth/auth.controller';
import { listLogs } from '../../lib/audit/audit.service';
import '../../styles/admin.css';

export const prerender = false;

// Check auth server-side
const { session, error } = requireAdmin(Astro.locals);

if (error || !session) {
  return Astro.redirect('/admin/login');
}

// Fetch logs for render
const logs = await listLogs();

// Helper to format action names
const formatAction = (action: string) => {
  return action.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
};

// Helper for status classes
const getActionClass = (action: string) => {
  if (action.includes('failure')) return 'status-bad';
  if (action.includes('success')) return 'status-good';
  if (action.includes('deleted')) return 'status-danger';
  return 'status-info';
};
---

<Layout 
  title="Audit Logs | Admin Dashboard" 
  description="Security and activity logs for MacDaly.com."
  fluid={true}
  hideHeader={true}
  hideFooter={true}
>
  <div class="admin-layout">
    <header class="admin-header">
      <div class="logo">MacDaly<span>.Admin</span></div>
      
      <div class="header-actions">
        <a href="/admin/dashboard" class="btn-link">← Inbox</a>
        <a href="/admin/export" class="btn-link">Export</a>
        <ThemeToggle />
        <button id="logoutBtn" class="btn-outline">Logout</button>
      </div>
    </header>

    <main class="admin-content">
      <div class="dashboard-intro">
        <h1>Audit Logs</h1>
        <p class="subtitle">System activity and security events tracking.</p>
      </div>

      <div class="dashboard-main mt-8">
        <div class="glass-panel no-padding overflow-hidden">
          <div class="table-container">
            <table class="logs-table">
              <thead>
                <tr>
                  <th>Timestamp</th>
                  <th>Admin</th>
                  <th>Action</th>
                  <th>Details</th>
                  <th>IP</th>
                </tr>
              </thead>
              <tbody>
                {logs.length === 0 ? (
                  <tr>
                    <td colspan="5" class="empty-state">No audit logs found.</td>
                  </tr>
                ) : (
                  logs.map((log) => (
                    <tr>
                      <td class="timestamp">{new Date(log.timestamp).toLocaleString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</td>
                      <td class="admin-id"><code>{log.admin_id.substring(0, 8)}</code></td>
                      <td>
                        <span class={`action-badge ${getActionClass(log.action)}`}>
                          {formatAction(log.action)}
                        </span>
                      </td>
                      <td class="metadata">
                        <details>
                          <summary>View Data</summary>
                          <pre>{JSON.stringify(log.metadata, null, 2)}</pre>
                        </details>
                      </td>
                      <td class="ip">{log.ip_address || '—'}</td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  const logoutBtn = document.getElementById('logoutBtn');
  
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      try {
        const csrfTag = document.querySelector('meta[name="csrf-token"]');
        const csrfToken = csrfTag ? csrfTag.getAttribute('content') : '';
        
        const response = await fetch('/admin/logout', { 
          method: 'POST',
          headers: { 
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-Token': csrfToken || ''
          }
        });
        
        if (response.ok) {
          window.location.href = '/admin/login';
        } else {
          alert('We were unable to log you out. Please try again.');
        }
      } catch (err) {
        console.error('Logout failed', err);
        alert('We were unable to log you out. Please try again.');
      }
    });
  }
</script>

<style>
  .no-padding { padding: 0; }
  .overflow-hidden { overflow: hidden; }

  .logs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .logs-table th {
    padding: 1.25rem 1.5rem;
    background: rgba(0,0,0,0.01);
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--glass-border);
    text-align: left;
  }

  .logs-table td {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--glass-border);
    vertical-align: middle;
  }

  .timestamp { color: var(--text-muted); font-family: monospace; }
  .ip { color: var(--text-muted); font-size: 0.8rem; }

  .admin-id code {
    background: var(--glass-border);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--tech-blue);
  }

  .action-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
  }

  .status-info { background: rgba(30, 168, 236, 0.1); color: #0284c7; }
  .status-good { background: rgba(16, 185, 129, 0.1); color: #059669; }
  .status-bad { background: rgba(239, 68, 68, 0.1); color: #dc2626; }
  .status-danger { background: rgba(245, 158, 11, 0.1); color: #d97706; }

  .metadata details summary {
    cursor: pointer;
    color: var(--tech-blue);
    font-weight: 600;
    font-size: 0.8rem;
    outline: none;
  }

  .metadata pre {
    margin-top: 0.5rem;
    padding: 1rem;
    background: #0f172a;
    color: #94a3b8;
    border-radius: 8px;
    font-size: 0.75rem;
    overflow-x: auto;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .empty-state {
    text-align: center;
    padding: 4rem !important;
    color: var(--text-muted);
  }

  .table-container { overflow-x: auto; }

  @media (max-width: 768px) {
    .logs-table th:nth-child(4), .logs-table td:nth-child(4),
    .logs-table th:nth-child(5), .logs-table td:nth-child(5) {
      display: none;
    }
  }
</style>
