---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const garageCol = await getCollection('automotive');
const garage = await Promise.all(garageCol.map(async (car) => {
	const { Content } = await render(car);
	return {
		data: car.data,
		Content
	};
}));
---

<Layout title="Garage & Build Logs | RedApe" description="Automotive builds, spec sheets, and track day logs.">
	
	<!-- Import a mechanical google font for this page selectively -->
	<style is:inline>
		@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
	</style>

	<div class="auto-container">
		
		<header class="auto-header">
			<h1 class="mech-title">The Garage</h1>
			<p class="mech-subtitle">Spec Sheets & Build Logs // Initialize</p>
			<div class="caution-tape"></div>
		</header>

		<div class="garage-roster">
			{garage.map(({ data: car, Content }) => (
				<article class="car-profile" key={car.id}>
					
					<div class="car-hero">
						<div class="car-image-wrapper">
							<!-- LAZY LOAD APPLIED HERE -->
							<img 
								src={car.placeholderImage} 
								alt={`Photo of ${car.name}`} 
								loading="lazy" 
								class="car-image"
							/>
							<div class="car-overlay"></div>
						</div>
						<div class="car-badge">
							<h2>{car.name}</h2>
							<span class="car-meta">CHASSIS: {car.year} | CLASSIFICATION: {car.type}</span>
						</div>
					</div>

					<div class="car-details-grid">
						
						<!-- Spec Sheet -->
						<div class="spec-sheet">
							<h3 class="section-heading">/// SPEC_SHEET</h3>
							<ul class="spec-list">
								{Object.entries(car.specs).map(([key, value]) => (
									<li class="spec-item" key={key}>
										<span class="spec-key">[{key}]</span>
										<span class="spec-value">{String(value)}</span>
									</li>
								))}
							</ul>
						</div>

						<!-- Build Log System (Rendered from Markdown Body) -->
						<div class="build-logs markdown-body">
							<Content />
						</div>

					</div>
				</article>
			))}
		</div>
	</div>
</Layout>

<style>
/* Automotive Base */
.auto-container {
	max-width: 1200px;
	margin: 0 auto;
	padding-bottom: 5rem;
	/* Apply the mechanical font locally to the container */
	font-family: 'Share Tech Mono', monospace; 
}

/* Header */
.auto-header {
	margin-bottom: 4rem;
	position: relative;
	padding-bottom: 2rem;
}

.mech-title {
	font-size: clamp(3rem, 6vw, 5rem);
	text-transform: uppercase;
	color: #fff;
	text-shadow: 2px 2px 0px #ef4444;
	margin-bottom: 0.5rem;
}

.mech-subtitle {
	color: #8b8e98;
	font-size: 1.2rem;
	letter-spacing: 2px;
	text-transform: uppercase;
}

.caution-tape {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 8px;
	background: repeating-linear-gradient(
		45deg,
		#ef4444,
		#ef4444 10px,
		#111 10px,
		#111 20px
	);
}

/* Vehicle Profiles */
.car-profile {
	margin-bottom: 6rem;
	background: rgba(15, 15, 15, 0.6);
	border: 1px solid #333;
	border-radius: 4px;
	overflow: hidden;
}

/* Hero & Images */
.car-hero {
	position: relative;
	width: 100%;
	aspect-ratio: 21/9;
	background: #000;
	overflow: hidden;
}

.car-image-wrapper {
	width: 100%;
	height: 100%;
	position: relative;
}

.car-image {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.8s ease;
}

.car-hero:hover .car-image {
	transform: scale(1.05); /* Slight zoom on hover */
}

.car-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
}

.car-badge {
	position: absolute;
	bottom: 2rem;
	left: 2rem;
	z-index: 2;
}

.car-badge h2 {
	font-size: clamp(2rem, 4vw, 3rem);
	color: #fff;
	text-transform: uppercase;
	margin-bottom: 0.25rem;
	text-shadow: 0 4px 10px rgba(0,0,0,0.8);
}

.car-meta {
	display: inline-block;
	background: #ef4444;
	color: #111;
	padding: 0.25rem 0.75rem;
	font-weight: bold;
	font-size: 0.9rem;
	letter-spacing: 1px;
}

/* Details Grid */
.car-details-grid {
	display: grid;
	grid-template-columns: 1fr 1.5fr; /* Spec sheet left, Logs right on desktop */
	gap: 3rem;
	padding: 3rem 2rem;
}

@media (max-width: 900px) {
	.car-details-grid {
		grid-template-columns: 1fr;
	}
	.car-hero {
		aspect-ratio: 16/9;
	}
}

.section-heading {
	color: #ef4444;
	font-size: 1.25rem;
	margin-bottom: 2rem;
	letter-spacing: 2px;
	border-bottom: 1px dashed #333;
	padding-bottom: 0.5rem;
}

/* Spec Sheet */
.spec-list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.spec-item {
	display: flex;
	flex-direction: column;
	border-left: 2px solid #333;
	padding-left: 1rem;
	transition: border-color 0.3s ease;
}

.spec-item:hover {
	border-color: #ef4444;
}

.spec-key {
	color: #8b8e98;
	font-size: 0.85rem;
	margin-bottom: 0.25rem;
}

.spec-value {
	color: #fff;
	font-size: 1.1rem;
}

/* Markdown Rendered Content Adjustments */
.markdown-body h3 {
	color: #ef4444;
	font-size: 1.25rem;
	margin-bottom: 2rem;
	letter-spacing: 2px;
	border-bottom: 1px dashed #333;
	padding-bottom: 0.5rem;
	text-transform: uppercase;
}

.markdown-body p {
	color: #aaa;
	font-size: 0.95rem;
	line-height: 1.6;
	font-family: var(--font-body);
	margin-bottom: 2rem;
	background: rgba(255, 255, 255, 0.02);
	border: 1px solid rgba(255, 255, 255, 0.05);
	padding: 1.5rem;
	position: relative;
	margin-left: 2rem;
}

/* Simulated Timeline Look */
.markdown-body strong {
	display: block;
	color: #ef4444;
	font-size: 0.9rem;
	margin-bottom: 0.5rem;
	font-family: 'Share Tech Mono', monospace;
	position: relative;
	margin-left: 2rem;
}

.markdown-body strong::before {
	content: '>';
	position: absolute;
	left: -2.4rem;
	color: #ef4444;
	background: #0d0f12;
	padding: 0 0.2rem;
	font-weight: bold;
}

/* Provide a line down the left side connecting the items */
.build-logs {
	position: relative;
}

.build-logs::before {
	content: '';
	position: absolute;
	left: 0;
	top: 3.5rem; /* Start below the h3 heading */
	bottom: 0;
	width: 1px;
	background: #333;
}
</style>
