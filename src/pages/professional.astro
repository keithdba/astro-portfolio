---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// Retrieve all Professional data via Collections API
const profileCol = await getCollection('professional-profile');
const profile = profileCol[0].data;

const rolesCol = await getCollection('professional-roles');
// Sort by duration roughly (in a real app you might want sortable date fields, relying on order here)
const roles = rolesCol.map(r => r.data);

const speakingCol = await getCollection('professional-speaking');
const speaking = speakingCol.map(s => s.data);
---

<Layout title="Executive Profile | RedApe" description="Professional portfolio, resume, and speaking engagements.">
	<div class="executive-container">
		
		<!-- Hero Section -->
		<header class="executive-hero">
			<div class="hero-content">
				<h1 class="exec-title">{profile.name}</h1>
				<h2 class="exec-subtitle">{profile.title}</h2>
				<p class="exec-summary">{profile.summary}</p>
				
				<div class="cta-group">
					<a href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer" class="btn-executive">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						Connect on LinkedIn
					</a>
					<a href={`mailto:${profile.contact.email}`} class="btn-ghost-exec">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
						Contact Me
					</a>
				</div>
			</div>
			
			<div class="hero-decorative">
				<div class="grid-pattern"></div>
			</div>
		</header>

		<!-- Career Narrative -->
		<section class="exec-section">
			<div class="section-header">
				<h3>Career Narrative</h3>
				<div class="header-line"></div>
			</div>
			
			<div class="timeline">
				{roles.map((role) => (
					<div class="timeline-item" key={role.id}>
						<div class="timeline-dot"></div>
						<div class="timeline-content glass-panel-exec">
							<div class="role-header">
								<div>
									<h4>{role.title}</h4>
									<span class="company">{role.company}</span>
								</div>
								<div class="duration">{role.duration}</div>
							</div>
							<p class="role-desc">{role.description}</p>
							<ul class="role-highlights">
								{role.highlights.map((highlight) => (
									<li>{highlight}</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Speaking Engagements -->
		<section class="exec-section">
			<div class="section-header">
				<h3>Executive Speaking</h3>
				<div class="header-line"></div>
			</div>
			
			<div class="speaking-grid">
				{speaking.map((event) => (
					<div class="speaking-card glass-panel-exec" key={event.id}>
						<div class="event-meta">
							<span class="event-date">{event.date}</span>
							<span class="event-location">{event.location}</span>
						</div>
						<h4 class="event-topic">"{event.topic}"</h4>
						<p class="event-name">{event.event}</p>
					</div>
				))}
			</div>
		</section>
		
	</div>
</Layout>

<style>
/* Executive Base */
.executive-container {
	max-width: 1000px;
	margin: 0 auto;
	padding-bottom: 4rem;
}

/* Typography Overrides for Exec Feel */
.exec-title {
	font-size: clamp(2.5rem, 5vw, 4rem);
	font-weight: 800;
	letter-spacing: -1px;
	color: #ffffff;
	line-height: 1.1;
	margin-bottom: 0.5rem;
}

.exec-subtitle {
	font-size: clamp(1.2rem, 2vw, 1.5rem);
	font-weight: 400;
	color: #38bdf8; /* Authoritative blue accent */
	margin-bottom: 1.5rem;
	letter-spacing: 0.5px;
}

.exec-summary {
	font-size: 1.1rem;
	color: var(--text-muted);
	max-width: 700px;
	margin-bottom: 2.5rem;
	line-height: 1.8;
}

/* Hero Section */
.executive-hero {
	position: relative;
	padding: 4rem 0 6rem 0;
	display: flex;
	align-items: center;
	border-bottom: 1px solid rgba(255,255,255,0.05);
	margin-bottom: 5rem;
}

.hero-content {
	position: relative;
	z-index: 2;
}

/* Decorative Background */
.hero-decorative {
	position: absolute;
	top: 0;
	right: 0;
	width: 50%;
	height: 100%;
	z-index: 1;
	opacity: 0.05;
	mask-image: linear-gradient(to left, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
	-webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 0%, rgba(0,0,0,0) 100%);
}

.grid-pattern {
	width: 100%;
	height: 100%;
	background-image: 
		linear-gradient(to right, #ffffff 1px, transparent 1px),
		linear-gradient(to bottom, #ffffff 1px, transparent 1px);
	background-size: 40px 40px;
}

/* Calls to Action */
.cta-group {
	display: flex;
	gap: 1.5rem;
	flex-wrap: wrap;
}

.btn-executive {
	display: inline-flex;
	align-items: center;
	gap: 0.75rem;
	padding: 0.8rem 2rem;
	background: #ffffff;
	color: #0d0f12;
	border-radius: 4px; /* Harder edge, more executive than pills */
	font-weight: 600;
	transition: all 0.3s ease;
}

.btn-executive:hover {
	background: #38bdf8;
	color: #0f172a;
	box-shadow: 0 4px 20px rgba(56,189,248,0.3);
}

.btn-ghost-exec {
	display: inline-flex;
	align-items: center;
	gap: 0.75rem;
	padding: 0.8rem 2rem;
	background: transparent;
	color: #ffffff;
	border: 1px solid rgba(255,255,255,0.2);
	border-radius: 4px;
	font-weight: 600;
	transition: all 0.3s ease;
}

.btn-ghost-exec:hover {
	border-color: #ffffff;
	background: rgba(255,255,255,0.05);
}

/* Section Headers */
.exec-section {
	margin-bottom: 5rem;
}

.section-header {
	display: flex;
	align-items: center;
	gap: 1.5rem;
	margin-bottom: 3rem;
}

.section-header h3 {
	font-size: 1.75rem;
	font-weight: 600;
	white-space: nowrap;
}

.header-line {
	height: 1px;
	width: 100%;
	background: linear-gradient(to right, rgba(255,255,255,0.1), transparent);
}

/* Glass Panel Exec Trim */
.glass-panel-exec {
	background: rgba(15, 23, 42, 0.4);
	border: 1px solid rgba(255, 255, 255, 0.05);
	border-radius: 8px;
	padding: 2.5rem;
	transition: all 0.3s ease;
}
.glass-panel-exec:hover {
	border-color: rgba(56,189,248,0.3);
	background: rgba(15, 23, 42, 0.6);
}

/* Timeline */
.timeline {
	position: relative;
	padding-left: 2rem;
}

.timeline::before {
	content: '';
	position: absolute;
	top: 0;
	bottom: 0;
	left: 0;
	width: 1px;
	background: rgba(255,255,255,0.1);
}

.timeline-item {
	position: relative;
	margin-bottom: 3rem;
}

.timeline-item:last-child {
	margin-bottom: 0;
}

.timeline-dot {
	position: absolute;
	left: -2rem;
	top: 2rem;
	width: 12px;
	height: 12px;
	border-radius: 50%;
	background: #0d0f12;
	border: 2px solid #38bdf8;
	transform: translateX(-50%);
}

/* Role Content */
.role-header {
	display: flex;
	justify-content: space-between;
	align-items: flex-start;
	flex-wrap: wrap;
	gap: 1rem;
	margin-bottom: 1.5rem;
}

.role-header h4 {
	font-size: 1.4rem;
	font-weight: 600;
	color: #fff;
	margin-bottom: 0.25rem;
}

.company {
	font-size: 1rem;
	color: #38bdf8;
	font-weight: 500;
}

.duration {
	font-family: monospace;
	font-size: 0.9rem;
	color: var(--text-muted);
	background: rgba(255,255,255,0.05);
	padding: 0.25rem 0.75rem;
	border-radius: 4px;
}

.role-desc {
	font-size: 1.05rem;
	line-height: 1.7;
	color: rgba(255,255,255,0.8);
	margin-bottom: 1.5rem;
}

.role-highlights {
	list-style: none;
	padding: 0;
	margin: 0;
}

.role-highlights li {
	position: relative;
	padding-left: 1.5rem;
	margin-bottom: 0.75rem;
	color: var(--text-muted);
}

.role-highlights li::before {
	content: '▹';
	position: absolute;
	left: 0;
	color: #38bdf8;
}

/* Speaking Engagements */
.speaking-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
	gap: 1.5rem;
}

.speaking-card {
	padding: 2rem;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.event-meta {
	display: flex;
	justify-content: space-between;
	font-family: monospace;
	font-size: 0.85rem;
	color: var(--text-muted);
	border-bottom: 1px solid rgba(255,255,255,0.1);
	padding-bottom: 0.5rem;
}

.event-topic {
	font-size: 1.2rem;
	line-height: 1.4;
	color: #fff;
	flex-grow: 1;
}

.event-name {
	color: #38bdf8;
	font-size: 0.9rem;
	font-weight: 600;
}

/* Responsive Overrides */
@media (max-width: 768px) {
	.role-header {
		flex-direction: column;
	}
	.timeline {
		padding-left: 1.5rem;
	}
	.timeline-dot {
		left: -1.5rem;
	}
	.glass-panel-exec {
		padding: 1.5rem;
	}
}
</style>
