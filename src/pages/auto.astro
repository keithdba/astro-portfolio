---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const garageCol = await getCollection('auto');
---

<Layout title="Garage & Build Logs | MacDaly.com" description="Automotive builds, spec sheets, and track day logs.">
	
	<!-- Import a mechanical google font for this page selectively -->
	<style is:inline>
		@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
	</style>

	<div class="auto-container">
		
		<header class="auto-header">
			<h1 class="mech-title">The Garage</h1>
			<p class="mech-subtitle">Spec Sheets & Build Logs // Initialize</p>
			<div class="caution-tape"></div>
		</header>

		<nav class="auto-tabs" aria-label="Automotive Section Navigation">
			<a href="/auto" class="auto-tab active">The Garage</a>
			<a href="/auto/project-vehicles" class="auto-tab">Project Vehicles</a>
		</nav>

		<div class="garage-grid">
			<a class="car-card" href="/auto/project-vehicles">
				<div class="card-image-wrapper">
					<img 
						src="/assets/auto/garage-projects.jpg" 
						alt="Project Vehicles" 
						class="card-image"
					/>
					<div class="card-overlay"></div>
				</div>
				<div class="card-content">
					<h2>Project Vehicles</h2>
					<span class="card-meta">DETAILED BUILDS // PERFORMANCE TUNING</span>
				</div>
			</a>
			<a class="car-card" href="/auto/products">
				<div class="card-image-wrapper">
					<img 
						src="/assets/auto/garage-products.jpg" 
						alt="Product Reviews" 
						class="card-image"
					/>
					<div class="card-overlay"></div>
				</div>
				<div class="card-content">
					<h2>Product Reviews</h2>
					<span class="card-meta">STAGED RELEASES // COMING SOON</span>
				</div>
			</a>
		</div>

	</div>
</Layout>

<style>
/* Automotive Base */
.auto-container {
	max-width: 1200px;
	margin: 0 auto;
	padding-bottom: 5rem;
	/* Apply the mechanical font locally to the container */
	font-family: 'Share Tech Mono', monospace; 
}

/* Header */
.auto-header {
	margin-bottom: 4rem;
	position: relative;
	padding-bottom: 2rem;
}

.mech-title {
	font-size: clamp(3rem, 6vw, 5rem);
	text-transform: uppercase;
	color: var(--accent-graphite);
	text-shadow: 2px 2px 0px var(--tech-blue);
	margin-bottom: 0.5rem;
}

.mech-subtitle {
	color: var(--text-muted);
	font-size: 1.2rem;
	letter-spacing: 2px;
	text-transform: uppercase;
}

.caution-tape {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 100%;
	height: 8px;
	background: repeating-linear-gradient(
		45deg,
		var(--tech-blue),
		var(--tech-blue) 10px,
		var(--accent-graphite) 10px,
		var(--accent-graphite) 20px
	);
}

/* Garage Grid */
.garage-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
	gap: 2.5rem;
}

/* Tab Navigation - Unified Segmented Control Style */
.auto-tabs {
  display: inline-flex;
  background: #f1f5f9;
  padding: 4px;
  border-radius: 12px;
  gap: 2px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  margin-bottom: 3rem;
  font-family: 'Inter', sans-serif; /* Use clean interlaced font for controls */
}

.auto-tab {
	text-decoration: none;
	background: transparent;
	border: none;
	padding: 0.625rem 1.75rem;
	font-size: 0.75rem;
	font-weight: 600;
	color: #64748b;
	cursor: pointer;
	letter-spacing: 0.05em;
	text-transform: uppercase;
	transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	border-radius: 8px;
}

.auto-tab:hover:not(.active) {
	color: var(--accent-graphite);
	background: rgba(255, 255, 255, 0.5);
}

.auto-tab.active {
	background: #fff;
	color: var(--tech-blue);
	box-shadow: 0 4px 12px -4px rgba(30, 168, 236, 0.12), 0 2px 4px -2px rgba(30, 168, 236, 0.04);
}

.car-card {
	display: block;
	text-decoration: none;
	background: #ffffff;
	border: 1px solid var(--performance-silver);
	border-radius: 4px;
	overflow: hidden;
	transition: all 0.3s ease;
	position: relative;
}

.car-card:hover {
	border-color: var(--tech-blue);
	transform: translateY(-5px);
	box-shadow: 0 10px 30px rgba(30, 168, 236, 0.15);
}

.card-image-wrapper {
	width: 100%;
	aspect-ratio: 16/9;
	position: relative;
	overflow: hidden;
	background: #000;
}

.card-image {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.8s ease;
}

.car-card:hover .card-image {
	transform: scale(1.05);
}

.card-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(to top, rgba(255,255,255,0.95) 0%, transparent 70%);
	pointer-events: none;
}

.card-content {
	padding: 1.5rem;
	position: relative;
	z-index: 2;
}

.card-content h2 {
	font-size: 1.5rem;
	color: var(--accent-graphite);
	text-transform: uppercase;
	margin-bottom: 0.5rem;
	line-height: 1.2;
}

.card-meta {
	display: inline-block;
	color: var(--text-muted);
	font-size: 0.85rem;
	letter-spacing: 1px;
	margin-top: 0.5rem;
}

/* Mechanical corner accent */
.car-card::after {
	content: '';
	position: absolute;
	bottom: 0;
	right: 0;
	width: 20px;
	height: 20px;
	background: linear-gradient(135deg, transparent 50%, var(--performance-silver) 50%);
	transition: background 0.3s ease;
}

.car-card:hover::after {
	background: linear-gradient(135deg, transparent 50%, var(--tech-blue) 50%);
}
</style>
