---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Login | MacDaly.com" description="Secure login for MacDaly.com administration.">
  <div class="login-container">
    <div class="login-card glass">
      <div class="login-header">
        <h1>Admin Access</h1>
        <p>Enter your credentials to manage the platform.</p>
      </div>

      <form id="loginForm" class="login-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required autocomplete="username" placeholder="Enter username" />
        </div>
        
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
        </div>

        <div class="captcha-wrapper">
          <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>
        </div>

        <div id="loginStatus" class="status-message" style="display: none;"></div>

        <button type="submit" id="loginBtn" class="btn-primary">
          <span>Authenticate</span>
          <div class="loader" id="loader" style="display: none;"></div>
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const loginForm = document.getElementById('loginForm') as HTMLFormElement;
  const statusDiv = document.getElementById('loginStatus');
  const loginBtn = document.getElementById('loginBtn');
  const loader = document.getElementById('loader');

  if (loginForm) {
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!loginBtn || !statusDiv || !loader) return;

      // Reset state
      loginBtn.disabled = true;
      loader.style.display = 'inline-block';
      statusDiv.style.display = 'none';
      statusDiv.className = 'status-message';

      const formData = new FormData(loginForm);
      const payload = {
        username: formData.get('username'),
        password: formData.get('password'),
        captchaToken: formData.get('cf-turnstile-response'),
      };

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (response.ok) {
          statusDiv.innerText = 'Authenticated! Redirecting...';
          statusDiv.classList.add('success');
          statusDiv.style.display = 'block';
          
          setTimeout(() => {
            window.location.href = '/admin/dashboard';
          }, 1000);
        } else {
          statusDiv.innerText = result.error || 'Authentication failed.';
          statusDiv.classList.add('error');
          statusDiv.style.display = 'block';
          loginBtn.disabled = false;
          
          // Reset Turnstile on failure
          if (window.turnstile) {
            window.turnstile.reset();
          }
        }
      } catch (err) {
        statusDiv.innerText = 'Network error. Please try again.';
        statusDiv.classList.add('error');
        statusDiv.style.display = 'block';
        loginBtn.disabled = false;
      } finally {
        loader.style.display = 'none';
      }
    });
  }
</script>


<style>
  .login-container {
    min-height: calc(100vh - 300px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .login-card {
    width: 100%;
    max-width: 400px;
    padding: 3rem;
    border-radius: 1.5rem;
    border: 1px solid var(--glass-border);
    box-shadow: 0 30px 60px rgba(0,0,0,0.12);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .login-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--accent-graphite);
  }

  .login-header p {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .captcha-wrapper {
    margin: 0.5rem 0;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .form-group input {
    padding: 0.9rem;
    border: 1px solid var(--performance-silver);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.5);
    transition: all 0.2s ease;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--tech-blue);
    box-shadow: 0 0 0 3px rgba(0, 153, 255, 0.1);
  }

  .btn-primary {
    background: var(--accent-graphite);
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .btn-primary:hover:not(:disabled) {
    background: #000000;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .btn-primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .status-message {
    padding: 0.8rem;
    border-radius: 6px;
    font-size: 0.9rem;
    text-align: center;
  }

  .status-message.error {
    background: #fff5f5;
    color: #c53030;
    border: 1px solid #feb2b2;
  }

  .status-message.success {
    background: #f0fff4;
    color: #276749;
    border: 1px solid #9ae6b4;
  }

  .loader {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
