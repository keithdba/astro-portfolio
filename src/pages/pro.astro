---
import Layout from '../layouts/Layout.astro';
import ResumeTimeline from '../components/ResumeTimeline.astro';
import ProProjects from '../components/ProProjects.astro';
import { getCollection } from 'astro:content';

const proCol = await getCollection('pro');
const resumeEntry = proCol.find(p => p?.data?.type === 'resume');

if (!resumeEntry) {
  throw new Error("No resume document found in 'pro' collection. Ensure src/content/pro/resume.md exists and has type: 'resume'.");
}
---

<Layout title="Executive Profile | MacDaly.com" description="Professional portfolio, resume, and speaking engagements.">
  
  <nav class="pro-tabs" aria-label="Professional Section Navigation">
    <button class="pro-tab active" data-tab="resume" id="tab-resume">Executive Profile</button>
    <button class="pro-tab" data-tab="uiux" id="tab-uiux">AI & Vibe Coding Projects</button>
  </nav>

  <div id="panel-resume" class="pro-panel">
    <ResumeTimeline resume={resumeEntry} />
  </div>

  <div id="panel-uiux" class="pro-panel" hidden>
    <ProProjects projects={proCol} />
  </div>

</Layout>

<style>
  .pro-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 4rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding-bottom: 0;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .pro-tab {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.875rem 1.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #64748b;
    cursor: pointer;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    margin-bottom: -1px;
    border-radius: 0;
  }

  .pro-tab:hover {
    color: #0f172a;
  }

  .pro-tab.active {
    color: #0f172a;
    border-bottom-color: #0f172a;
  }

  .pro-panel {
    display: block;
  }

  .pro-panel[hidden] {
    display: none;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pro-tab');
  const panels = document.querySelectorAll<HTMLElement>('.pro-panel');

  function activateProTab(tabId: string) {
    const tabToActivate = Array.from(tabs).find(t => t.dataset.tab === tabId);
    if (!tabToActivate) return;

    tabs.forEach(t => t.classList.remove('active'));
    tabToActivate.classList.add('active');

    panels.forEach(panel => {
      if (panel.id === `panel-${tabId}`) {
        panel.removeAttribute('hidden');
      } else {
        panel.setAttribute('hidden', '');
      }
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      if (target) activateProTab(target);
    });
  });

  // Handle initial hash on load - if hash is one of the AI sub-tabs, show the AI Projects tab
  const aiSubTabs = ['architecture', 'process', 'projects'];
  window.addEventListener('load', () => {
    const hash = window.location.hash.replace('#', '');
    if (aiSubTabs.includes(hash)) {
      activateProTab('uiux');
    }
  });

  // Handle hash change
  window.addEventListener('hashchange', () => {
    const hash = window.location.hash.replace('#', '');
    if (aiSubTabs.includes(hash)) {
      activateProTab('uiux');
    }
  });
</script>

