---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{currentPath.startsWith('/pro') && (
			<style is:inline>
				:root {
					--accent: #64748b !important;
					--accent-glow: rgba(100, 116, 139, 0.2) !important;
				}
			</style>
		)}
		{currentPath.startsWith('/auto') && (
			<style is:inline>
				:root {
					--accent: #4682b4 !important;
					--accent-glow: rgba(70, 130, 180, 0.2) !important;
				}
			</style>
		)}
	</head>
	<body>
		<div class="container">
			<header class="nav-header">
				<a href="/" class="logo">MacDaly.com</a>
				<nav class="nav-links">
					<a href="/pro" class={`nav-link ${currentPath.startsWith('/pro') ? 'active' : ''}`}>Professional</a>
					<a href="/auto" class={`nav-link ${currentPath.startsWith('/auto') ? 'active' : ''}`}>Automotive</a>
				</nav>
			</header>
			<main>
				<slot />
			</main>
		</div>
	</body>
</html>
